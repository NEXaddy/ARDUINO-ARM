#include <Basicmicro.h>
#include <Wire.h>
#include <Adafruit_VL53L0X.h>
#include <Adafruit_ICM20948.h>
#include <Adafruit_ICM20X.h>
#include <Adafruit_Sensor.h>

#define TCAADDR 0x70
#define ROBOCLAW_ADDR 0x80

HardwareSerial RoboSerial(1);
Basicmicro roboclaw(&RoboSerial, 10000);

const int LINACTSWITCH = D2;
const int BACKSWITCH = D3;

const float PPR = 103.8;
const int MM_PER_REV = 8;

#define NUM_SENSORS 8
Adafruit_VL53L0X lox[NUM_SENSORS];
Adafruit_ICM20948 icm;


enum State {
  HOMING,
  IDLE,
  MOVING,
  FAULT
};

State currentState = HOMING;

unsigned long lastSensorRead = 0;
unsigned long lastDebug = 0;
const unsigned long SENSOR_INTERVAL = 100;   // ms
const unsigned long DEBUG_INTERVAL = 500;    // ms

uint16_t distances[NUM_SENSORS];
uint8_t status;
bool valid;

int32_t targetPosition = 0;
bool moveCommandSent = false;

const int CURRENT_LIMIT = 6000;  // mA
bool faultTriggered = false;

void tcaselect(uint8_t i) {
  if (i > 7) return;
  Wire.beginTransmission(TCAADDR);
  Wire.write(1 << i);
  Wire.endTransmission();
}

void stopMotor() {
  roboclaw.DutyM1(ROBOCLAW_ADDR, 0);
}

bool checkSafety() {
  if (digitalRead(LINACTSWITCH) == LOW || digitalRead(BACKSWITCH) == LOW) {
    Serial.println("LIMIT SWITCH TRIGGERED");
    return true;
  }

  int16_t c1, c2;
  if (roboclaw.ReadCurrents(ROBOCLAW_ADDR, c1, c2)) {
    if (c1 > CURRENT_LIMIT) {
      Serial.println("OVERCURRENT!");
      return true;
    }
  }

  return false;
}

void readSensors() {
  VL53L0X_RangingMeasurementData_t measure;

  for (uint8_t i = 0; i < NUM_SENSORS; i++) {
    if (i == 3 || i == 4 || i == 5) continue;

    tcaselect(i);
    lox[i].rangingTest(&measure, false);

    if (measure.RangeStatus != 4) {
      distances[i] = measure.RangeMilliMeter;
    } else {
      distances[i] = 9999;
    }
  }
}

void setup() {
  pinMode(LINACTSWITCH, INPUT_PULLUP);
  pinMode(BACKSWITCH, INPUT_PULLUP);

  Serial.begin(38400);
  RoboSerial.begin(38400);
  roboclaw.begin(38400);
  Wire.begin();

  if (!icm.begin_I2C()) {
    Serial.println("IMU FAIL");
    while (1);
  }

  for (uint8_t i = 0; i < NUM_SENSORS; i++) {
    tcaselect(i);
    lox[i].begin();
  }

  roboclaw.SetM1MaxCurrent(ROBOCLAW_ADDR, 7000, 3000);
  roboclaw.SetM1VelocityPID(ROBOCLAW_ADDR, 1.0, 0.5, 0.25, 12000);

  roboclaw.ResetEncoders(ROBOCLAW_ADDR);
}

void loop() {

  if (checkSafety()) {
    stopMotor();
    currentState = FAULT;
  }

  unsigned long now = millis();

  if (now - lastSensorRead > SENSOR_INTERVAL) {
    readSensors();
    lastSensorRead = now;
  }
  
  switch (currentState) {

    case HOMING:
      if (digitalRead(BACKSWITCH) == HIGH) {
        roboclaw.DutyM1(ROBOCLAW_ADDR, -2000);
      } else {
        stopMotor();
        roboclaw.ResetEncoders(ROBOCLAW_ADDR);
        currentState = IDLE;
        Serial.println("HOMING COMPLETE");
      }
      break;

    case IDLE:
      if (distances[0] > 200) {   // example condition
        targetPosition = (int32_t)((PPR / MM_PER_REV) * 15);
        moveCommandSent = false;
        currentState = MOVING;
      }
      break;

    case MOVING:
      if (!moveCommandSent) {
        roboclaw.SpeedAccelDeccelPositionM1(
          ROBOCLAW_ADDR,
          2000,
          1500,
          2000,
          targetPosition,
          1
        );
        moveCommandSent = true;
      }

      {
        uint32_t enc = roboclaw.ReadEncM1(ROBOCLAW_ADDR, &status, &valid);
        if (valid && abs((int32_t)enc - targetPosition) < 10) {
          Serial.println("TARGET REACHED");
          currentState = IDLE;
        }
      }
      break;

    case FAULT:
      stopMotor();
      // stays here until reset
      break;
  }

  if (now - lastDebug > DEBUG_INTERVAL) {
    Serial.print("State: ");
    Serial.println(currentState);

    for (int i = 0; i < NUM_SENSORS; i++) {
      Serial.print(distances[i]);
      Serial.print(" ");
    }
    Serial.println();

    lastDebug = now;
  }
}
